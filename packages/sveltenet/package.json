{
	"name": "sveltenet",
	"version": "0.1.0",
	"description": "Svelte 5 islands for ASP.NET — Vite plugin and runtime helpers",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/datstarkey/sveltenet.git",
		"directory": "packages/sveltenet"
	},
	"type": "module",
	"scripts": {
		"test": "node --test test/*.test.mjs && vitest run --config vitest.config.js",
		"check": "tsc --noEmit"
	},
	"exports": {
		"./vite": {
			"types": "./src/vite.d.ts",
			"default": "./src/vite.js"
		},
		"./client": {
			"types": "./src/client.d.ts",
			"default": "./src/client.js"
		},
		"./async-hooks": {
			"default": "./src/async-hooks.js"
		},
		"./remote": {
			"types": "./src/remote.svelte.d.ts",
			"svelte": "./src/remote.svelte.js",
			"default": "./src/remote.svelte.js"
		},
		"./server": {
			"types": "./src/server.d.ts",
			"default": "./src/server.js"
		}
	},
	"files": [
		"src/*.js",
		"src/*.d.ts"
	],
	"peerDependencies": {
		"svelte": "^5.46.0",
		"vite": "^8.0.0"
	},
	"dependencies": {
		"@sveltejs/vite-plugin-svelte": "^7.0.0"
	},
	"devDependencies": {
		"@vitest/browser-playwright": "^4.1.10",
		"happy-dom": "^20.0.0",
		"playwright": "^1.61.1",
		"svelte": "^5.46.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.10"
	}
}
