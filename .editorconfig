root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,js,mjs,ts,svelte}]
indent_style = tab
indent_size = 4

[*.{json,jsonc,yml,yaml,md,csproj,props,targets,slnx}]
indent_style = space
indent_size = 2

[*.cs]
dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all

